{
  "name": "milio",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:unit": "jest --testPathPatterns='src/.*\\.test\\.ts$'",
    "test:domain": "vitest run src/domain",
    "features": "cucumber-js"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo[^/]*|@expo[^/]*/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand)/)"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@hookform/resolvers": "^5.2.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.2.0",
    "lucide-react-native": "^1.16.0",
    "react": "19.1.0",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.5.0",
    "@cucumber/cucumber": "^12.9.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.8.0",
    "@types/react": "~19.1.0",
    "@vitest/ui": "^4.1.6",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2",
    "ulid": "^3.0.2",
    "vitest": "^4.1.6"
  },
  "private": true
}
